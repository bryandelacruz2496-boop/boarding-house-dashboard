<%- include('partials/header') %>

<div class="page-header">
  <h1>Dashboard</h1>
  <span class="badge"><%= currentMonth %> <%= currentYear %></span>
  <span class="dashboard-time" id="dashboardTime" style="margin-left: auto; font-size: 1.1rem; color: #1e293b; font-weight: 600;"></span>
</div>

<!-- Month/Year Filter -->
<div class="card">
  <form class="filter-form" method="GET" action="/dashboard" id="dashboardFilter">
    <select name="month" onchange="document.getElementById('dashboardFilter').submit()">
      <% months.forEach(m => { %>
        <option value="<%= m %>" <%= m === currentMonth ? 'selected' : '' %>><%= m %></option>
      <% }) %>
    </select>
    <input type="number" name="year" value="<%= currentYear %>" min="2020" max="2030" onchange="document.getElementById('dashboardFilter').submit()">
    <button type="submit" class="btn btn-primary">Filter</button>
  </form>
</div>

<%
  // Trend badge renderer: positive change = good for collection/net, bad for outstanding/expenses
  function trendBadge(pct, higherIsBetter) {
    if (pct === null || pct === undefined) return '<span class="stat-trend trend-flat">— new</span>';
    const rounded = Math.round(pct);
    if (rounded === 0) return '<span class="stat-trend trend-flat">0% vs last month</span>';
    const up = rounded > 0;
    const good = higherIsBetter ? up : !up;
    const arrow = up ? '&#9650;' : '&#9660;';
    const cls = good ? 'trend-up' : 'trend-down';
    return `<span class="stat-trend ${cls}">${arrow} ${Math.abs(rounded)}%</span><span class="stat-trend-note">vs last month</span>`;
  }
  const settledPct = totalRooms > 0 ? Math.round((settledCount / totalRooms) * 100) : 0;
%>
<!-- Summary Cards -->
<div class="stats-grid">
  <div class="stat-card stat-green">
    <div class="stat-card-top">
      <div class="stat-info">
        <h3>Total Collection</h3>
        <p class="stat-value" data-countup="<%= totalCollection %>">₱<%= totalCollection.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></p>
      </div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 21V3h5a4 4 0 0 1 0 8H8"/><path d="M5 8h11"/><path d="M5 12h11"/></svg></div>
    </div>
    <%- trendBadge(trends.collection, true) %>
  </div>
  <div class="stat-card stat-red">
    <div class="stat-card-top">
      <div class="stat-info">
        <h3>Outstanding Balance</h3>
        <p class="stat-value" data-countup="<%= totalOutstanding %>">₱<%= totalOutstanding.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></p>
      </div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
    </div>
    <%- trendBadge(trends.outstanding, false) %>
  </div>
  <div class="stat-card stat-blue">
    <div class="stat-card-top">
      <div class="stat-info">
        <h3>Total to Collect</h3>
        <p class="stat-value" data-countup="<%= totalCollection + totalOutstanding %>">₱<%= (totalCollection + totalOutstanding).toLocaleString('en-PH', {minimumFractionDigits: 2}) %></p>
      </div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
    </div>
  </div>
  <div class="stat-card stat-orange">
    <div class="stat-card-top">
      <div class="stat-info">
        <h3>Total Expenses</h3>
        <p class="stat-value" data-countup="<%= totalExpenses %>">₱<%= totalExpenses.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></p>
      </div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg></div>
    </div>
    <%- trendBadge(trends.expenses, false) %>
  </div>
  <div class="stat-card <%= netIncome >= 0 ? 'stat-green' : 'stat-red' %>">
    <div class="stat-card-top">
      <div class="stat-info">
        <h3>Net (Collection − Expenses)</h3>
        <p class="stat-value" data-countup="<%= netIncome %>">₱<%= netIncome.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></p>
      </div>
      <div class="stat-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
    </div>
    <%- trendBadge(trends.netIncome, true) %>
  </div>
</div>

<!-- Net Income Highlight -->
<div class="net-income-card <%= netIncome >= 0 ? 'net-positive' : 'net-negative' %>">
  <div class="net-income-main">
    <div class="net-income-label">NET INCOME - <%= currentMonth %> <%= currentYear %></div>
    <div class="net-income-value">₱<%= netIncome.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></div>
    <div class="net-income-detail">Collection ₱<%= totalCollection.toLocaleString('en-PH', {minimumFractionDigits: 2}) %> − Expenses ₱<%= totalExpenses.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></div>
  </div>
  <div class="net-income-spark">
    <span class="net-income-spark-label">6-Month Trend</span>
    <canvas id="netIncomeSparkline"></canvas>
  </div>
</div>

<!-- Room Collection Table -->
<div class="card">
  <div class="card-header">
    <h2>Room Collection - <%= currentMonth %></h2>
  </div>
  <div class="table-responsive">
    <table class="table table-cards">
      <thead>
        <tr>
          <th>Room</th>
          <th>Tenants</th>
          <th class="num">Total</th>
          <th class="num">Collected</th>
          <th>Status</th>
          <th class="num">Balance</th>
        </tr>
      </thead>
      <tbody>
        <% roomSummary.forEach(room => { %>
        <tr>
          <td data-label="Room"><strong>ROOM <%= room.room_number %></strong></td>
          <td data-label="Tenants"><%= room.tenantCount %> person<%= room.tenantCount !== 1 ? 's' : '' %></td>
          <td data-label="Total" class="num">₱<%= room.total.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></td>
          <td data-label="Collected" class="num">₱<%= (room.collected || 0).toLocaleString('en-PH', {minimumFractionDigits: 2}) %></td>
          <td data-label="Status">
            <span class="status-badge status-<%= room.status === 'SETTLED' ? 'settled' : room.status === 'PARTIAL' ? 'partial' : room.status === 'UNSETTLED' ? 'unsettled' : 'none' %>">
              <%= room.status %>
            </span>
          </td>
          <td data-label="Balance" class="num">₱<%= room.balance.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="2"><strong>OVERALL TOTAL</strong></td>
          <td class="num"><strong>₱<%= (totalCollection + totalOutstanding).toLocaleString('en-PH', {minimumFractionDigits: 2}) %></strong></td>
          <td></td>
          <td></td>
          <td class="num"><strong>₱<%= totalOutstanding.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></strong></td>
        </tr>
      </tfoot>
    </table>
  </div>
</div>

<!-- Charts Section -->
<div class="charts-grid">
  <!-- Expense Pie Chart -->
  <div class="card">
    <div class="card-header">
      <h2>Expense Breakdown - <%= currentMonth %></h2>
    </div>
    <div class="chart-container">
      <% if (Object.keys(expenseCategories).length === 0) { %>
        <div class="empty-state">
          <div class="empty-state-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg></div>
          <div class="empty-state-title">No expenses yet</div>
          <div class="empty-state-text">No expenses recorded for <%= currentMonth %> <%= currentYear %>.</div>
          <a href="/expenses" class="btn btn-primary btn-sm">Add Expense</a>
        </div>
      <% } else { %>
        <canvas id="expensePieChart"></canvas>
      <% } %>
    </div>
    <% if (Object.keys(expenseCategories).length > 0) { %>
    <div class="chart-legend">
      <% Object.entries(expenseCategories).forEach(([cat, amount]) => { %>
        <div class="legend-item">
          <span class="legend-label"><%= cat %></span>
          <span class="legend-value">₱<%= amount.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></span>
        </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <!-- Billing Breakdown Bar Chart -->
  <div class="card">
    <div class="card-header">
      <h2>Billing Breakdown - <%= currentMonth %></h2>
    </div>
    <div class="chart-container">
      <canvas id="billingBarChart"></canvas>
    </div>
  </div>
</div>

<!-- Room Collection Per Room Bar Chart -->
<div class="card">
  <div class="card-header">
    <h2>Collection Per Room - <%= currentMonth %></h2>
  </div>
  <div class="chart-container chart-wide">
    <canvas id="roomCollectionChart"></canvas>
  </div>
</div>

<!-- Recent Expenses -->
<div class="card">
  <div class="card-header">
    <h2>Expenses - <%= currentMonth %></h2>
    <a href="/expenses" class="btn btn-sm">View All</a>
  </div>
  <% if (expenses.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></div>
    <div class="empty-state-title">No expenses recorded</div>
    <div class="empty-state-text">Expenses for <%= currentMonth %> <%= currentYear %> will appear here once added.</div>
    <a href="/expenses" class="btn btn-primary btn-sm">Add Expense</a>
  </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table table-cards">
      <thead>
        <tr>
          <th>Date</th>
          <th class="num">Amount</th>
          <th>Reason</th>
        </tr>
      </thead>
      <tbody>
        <% expenses.slice(0, 5).forEach(exp => { %>
        <tr>
          <td data-label="Date"><%= exp.date %></td>
          <td data-label="Amount" class="num">₱<%= exp.amount.toLocaleString('en-PH', {minimumFractionDigits: 2}) %></td>
          <td data-label="Reason"><%= exp.reason %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  // Net Income Sparkline (6-month trend inside the hero banner)
  (function() {
    const el = document.getElementById('netIncomeSparkline');
    if (!el) return;
    const sparkData = <%- JSON.stringify(sparkline) %>;
    new Chart(el.getContext('2d'), {
      type: 'line',
      data: {
        labels: sparkData.map(d => d.label),
        datasets: [{
          data: sparkData.map(d => d.value),
          borderColor: 'rgba(255,255,255,0.95)',
          backgroundColor: 'rgba(255,255,255,0.15)',
          borderWidth: 2,
          fill: true,
          tension: 0.4,
          pointRadius: 0,
          pointHoverRadius: 4,
          pointHoverBackgroundColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              title: (items) => items[0].label,
              label: (ctx) => '₱' + ctx.parsed.y.toLocaleString()
            }
          }
        },
        scales: { x: { display: false }, y: { display: false } }
      }
    });
  })();

  // Expense Pie Chart
  <% if (Object.keys(expenseCategories).length > 0) { %>
  const expenseCtx = document.getElementById('expensePieChart').getContext('2d');
  new Chart(expenseCtx, {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(Object.keys(expenseCategories)) %>,
      datasets: [{
        data: <%- JSON.stringify(Object.values(expenseCategories)) %>,
        backgroundColor: [
          '#000035', '#1a237e', '#34a853', '#fbbc04', '#ff6d01', '#46bdc6', '#7b1fa2', '#ea4335'
        ],
        borderWidth: 2,
        borderColor: '#fff'
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { padding: 16, usePointStyle: true }
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const total = context.dataset.data.reduce((a, b) => a + b, 0);
              const percentage = ((context.parsed / total) * 100).toFixed(1);
              return `${context.label}: ₱${context.parsed.toLocaleString()} (${percentage}%)`;
            }
          }
        }
      }
    }
  });
  <% } %>

  // Billing Breakdown Bar Chart
  const billingCtx = document.getElementById('billingBarChart').getContext('2d');
  new Chart(billingCtx, {
    type: 'bar',
    data: {
      labels: ['Rent', 'WiFi', 'Electric', 'Water', 'Garbage', 'Penalty'],
      datasets: [{
        label: 'Amount (₱)',
        data: [
          <%= billingBreakdown.rent %>,
          <%= billingBreakdown.wifi %>,
          <%= billingBreakdown.electric %>,
          <%= billingBreakdown.water %>,
          <%= billingBreakdown.garbage %>,
          <%= billingBreakdown.penalty %>
        ],
        backgroundColor: ['#000035', '#34a853', '#fbbc04', '#46bdc6', '#ff6d01', '#ea4335'],
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(context) {
              return `₱${context.parsed.y.toLocaleString()}`;
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: function(value) { return '₱' + value.toLocaleString(); }
          }
        }
      }
    }
  });

  // Room Collection Chart
  const roomCtx = document.getElementById('roomCollectionChart').getContext('2d');
  new Chart(roomCtx, {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(roomSummary.map(r => 'Room ' + r.room_number)) %>,
      datasets: [{
        label: 'Collection (₱)',
        data: <%- JSON.stringify(roomSummary.map(r => r.total)) %>,
        backgroundColor: <%- JSON.stringify(roomSummary.map(r => r.status === 'SETTLED' ? '#34a853' : r.status === 'UNSETTLED' ? '#ea4335' : '#ccc')) %>,
        borderRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(context) {
              return `₱${context.parsed.y.toLocaleString()}`;
            }
          }
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: function(value) { return '₱' + value.toLocaleString(); }
          }
        }
      }
    }
  });
</script>

<script>
  // Persist selected month/year in localStorage
  const urlParams = new URLSearchParams(window.location.search);
  const selectedMonth = urlParams.get('month') || '<%= currentMonth %>';
  const selectedYear = urlParams.get('year') || '<%= currentYear %>';
  localStorage.setItem('dashboard_month', selectedMonth);
  localStorage.setItem('dashboard_year', selectedYear);

  // On page load without query params, redirect to saved month/year
  if (!urlParams.has('month') && !urlParams.has('year')) {
    const savedMonth = localStorage.getItem('dashboard_month');
    const savedYear = localStorage.getItem('dashboard_year');
    if (savedMonth && savedYear) {
      window.location.href = '/dashboard?month=' + savedMonth + '&year=' + savedYear;
    }
  }
</script>

<%- include('partials/footer') %>
