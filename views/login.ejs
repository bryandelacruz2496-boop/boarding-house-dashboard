<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - BH Manager</title>
  <!-- PWA Meta Tags -->
  <meta name="theme-color" content="#1a73e8">
  <meta name="description" content="Boarding house management dashboard for billing, rooms, and tenants">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="BH Dashboard">
  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">
  <!-- Apple Touch Icons -->
  <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/icons/icon-192x192.png">
  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="96x96" href="/icons/icon-96x96.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
  <div class="login-container">
    <div class="login-card">
      <div class="login-header">
        <h1>&#127936;</h1>
        <h2>BH Manager</h2>
        <p>Boarding House Management</p>
      </div>
      <% if (locked) { %>
        <div class="alert alert-error" style="text-align: center;">
          <strong>🔒 Account Locked</strong><br>
          Too many failed attempts. Try again in <span id="countdown"><%= lockRemaining %></span> seconds.
        </div>
        <form class="login-form">
          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" disabled placeholder="Enter username" style="opacity: 0.5;">
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" disabled placeholder="Enter password" style="opacity: 0.5;">
          </div>
          <button type="button" class="btn btn-primary btn-full" disabled style="opacity: 0.5;">Login</button>
        </form>
        <script>
          let seconds = <%= lockRemaining %>;
          const countdown = document.getElementById('countdown');
          const timer = setInterval(() => {
            seconds--;
            countdown.textContent = seconds;
            if (seconds <= 0) {
              clearInterval(timer);
              window.location.reload();
            }
          }, 1000);
        </script>
      <% } else { %>
        <% if (error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>
        <form action="/login" method="POST" class="login-form">
          <div class="form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" required placeholder="Enter username">
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Enter password">
          </div>
          <button type="submit" class="btn btn-primary btn-full">Login</button>
        </form>
      <% } %>
    </div>
  </div>
  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then((registration) => {
            console.log('SW registered:', registration.scope);
          })
          .catch((error) => {
            console.log('SW registration failed:', error);
          });
      });
    }
  </script>
</body>
</html>
