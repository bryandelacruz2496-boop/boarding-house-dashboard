<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Boarding House Dashboard</title>
  <!-- PWA Meta Tags -->
  <meta name="theme-color" content="#1a73e8">
  <meta name="description" content="Boarding house management dashboard for billing, rooms, and tenants">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="BH Dashboard">
  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">
  <!-- Apple Touch Icons -->
  <link rel="apple-touch-icon" sizes="152x152" href="/icons/icon-152x152.png">
  <link rel="apple-touch-icon" sizes="192x192" href="/icons/icon-192x192.png">
  <link rel="apple-touch-icon" sizes="512x512" href="/icons/icon-512x512.png">
  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="96x96" href="/icons/icon-96x96.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% if (user) { %>
  <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle menu">&#9776;</button>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <div class="app-layout">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-profile">
        <div class="profile-avatar">
          <span><%- user.avatar || '🏀' %></span>
        </div>
        <div class="profile-name"><%= user.username.toUpperCase() %></div>
        <div class="profile-role"><%= user.role === 'tenant' ? 'Tenant' : 'Property Manager' %></div>
      </div>
      <nav class="sidebar-nav">
        <% if (user.role === 'tenant') { %>
        <a href="/tenant" class="sidebar-link"><span class="link-icon">&#9632;</span> My Bills</a>
        <% } else { %>
        <a href="/dashboard" class="sidebar-link"><span class="link-icon">&#9632;</span> Dashboard</a>
        <a href="/billing" class="sidebar-link"><span class="link-icon">&#9632;</span> Billing</a>
        <a href="/computation" class="sidebar-link"><span class="link-icon">&#9632;</span> Computation</a>
        <a href="/expenses" class="sidebar-link"><span class="link-icon">&#9632;</span> Expenses</a>
        <a href="/rooms" class="sidebar-link"><span class="link-icon">&#9632;</span> Rooms</a>
        <% } %>
      </nav>
      <div class="sidebar-footer">
        <a href="/logout" class="sidebar-link sidebar-logout"><span class="link-icon">&#9632;</span> Logout</a>
      </div>
    </aside>
    <div class="main-content">
  <% } %>
  <main class="container">
