<%- include('partials/header') %>

<div class="page-header">
  <h1>Room Management</h1>
  <span class="badge">Max 5 tenants per room</span>
  <span class="dashboard-time" id="dashboardTime" style="margin-left: auto; font-size: 1.1rem; color: #1e293b; font-weight: 600;"></span>
</div>

<!-- Month/Year Filter -->
<div class="card">
  <form class="filter-form" method="GET" action="/rooms" id="roomsFilter">
    <select name="month" onchange="document.getElementById('roomsFilter').submit()">
      <% months.forEach(m => { %>
        <option value="<%= m %>" <%= m === month ? 'selected' : '' %>><%= m %></option>
      <% }) %>
    </select>
    <input type="number" name="year" value="<%= year %>" min="2020" max="2030" onchange="document.getElementById('roomsFilter').submit()">
    <button type="submit" class="btn btn-primary">Filter</button>
  </form>
</div>

<div class="rooms-grid">
  <% rooms.forEach(room => { %>
  <div class="room-card room-<%= room.status %>">
    <div class="room-header">
      <h3>Room <%= room.room_number %></h3>
      <span class="status-badge status-<%= room.status %>"><%= room.status %></span>
    </div>

    <!-- Tenant List -->
    <div class="tenant-list">
      <label class="form-label">Tenants (<%= room.tenants.length %>/5)</label>
      <% if (room.tenants.length === 0) { %>
        <p class="text-muted text-small">No tenants</p>
      <% } %>
      <% room.tenants.forEach(tenant => { %>
        <div class="tenant-item">
          <span class="tenant-name"><%= tenant.name %></span>
          <div class="tenant-actions">
            <form method="POST" action="/rooms/<%= room.id %>/tenants/<%= tenant.id %>/wifi" style="display:inline">
              <input type="hidden" name="month" value="<%= month %>">
              <input type="hidden" name="year" value="<%= year %>">
              <button type="submit" class="btn-wifi <%= tenant.has_wifi ? 'wifi-on' : 'wifi-off' %>" title="<%= tenant.has_wifi ? 'WiFi ON - click to turn off' : 'WiFi OFF - click to turn on' %>">
                WiFi <%= tenant.has_wifi ? 'ON' : 'OFF' %>
              </button>
            </form>
            <form method="POST" action="/rooms/<%= room.id %>/tenants/remove/<%= tenant.id %>" style="display:inline">
              <input type="hidden" name="month" value="<%= month %>">
              <input type="hidden" name="year" value="<%= year %>">
              <button type="submit" class="btn-remove" title="Remove tenant">✕</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Add Tenant Form -->
    <% if (room.tenants.length < 5) { %>
    <form method="POST" action="/rooms/<%= room.id %>/tenants/add" class="add-tenant-form">
      <input type="hidden" name="month" value="<%= month %>">
      <input type="hidden" name="year" value="<%= year %>">
      <input type="text" name="name" placeholder="New tenant name" required>
      <button type="submit" class="btn btn-primary btn-sm">Add</button>
    </form>
    <% } %>

    <!-- Room Status -->
    <form method="POST" action="/rooms/update/<%= room.id %>" class="room-status-form">
      <input type="hidden" name="month" value="<%= month %>">
      <input type="hidden" name="year" value="<%= year %>">
      <div class="form-group">
        <label>Status</label>
        <select name="status">
          <option value="occupied" <%= room.status === 'occupied' ? 'selected' : '' %>>Occupied</option>
          <option value="vacant" <%= room.status === 'vacant' ? 'selected' : '' %>>Vacant</option>
        </select>
      </div>
      <button type="submit" class="btn btn-secondary btn-sm">Update Status</button>
    </form>

    <!-- Room Account -->
    <div class="room-status-form">
      <label class="form-label">Tenant Login</label>
      <% if (room.account) { %>
        <p class="text-small" style="margin-bottom: 8px;">Account: <strong><%= room.account.username %></strong></p>
        <form method="POST" action="/rooms/<%= room.id %>/account/reset" style="margin-bottom: 6px;">
          <input type="hidden" name="month" value="<%= month %>">
          <input type="hidden" name="year" value="<%= year %>">
          <div style="display: flex; gap: 6px;">
            <input type="password" name="password" placeholder="New password" required style="flex:1; padding: 6px 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 12px;">
            <button type="submit" class="btn btn-secondary btn-sm">Reset</button>
          </div>
        </form>
        <form method="POST" action="/rooms/<%= room.id %>/account/delete">
          <input type="hidden" name="month" value="<%= month %>">
          <input type="hidden" name="year" value="<%= year %>">
          <button type="submit" class="btn btn-danger btn-sm">Remove Account</button>
        </form>
      <% } else { %>
        <form method="POST" action="/rooms/<%= room.id %>/account/create">
          <input type="hidden" name="month" value="<%= month %>">
          <input type="hidden" name="year" value="<%= year %>">
          <div style="display: flex; flex-direction: column; gap: 6px;">
            <input type="text" name="username" placeholder="Username (e.g. room1)" required style="padding: 6px 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 12px;">
            <input type="password" name="password" placeholder="Password" required style="padding: 6px 10px; border: 1px solid var(--border); border-radius: 8px; font-size: 12px;">
            <button type="submit" class="btn btn-primary btn-sm">Create Account</button>
          </div>
        </form>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>

<%- include('partials/footer') %>
